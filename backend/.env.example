# Rename this file to `.env` and fill values before running the backend.

# ── Database (Postgres for multi-user) ───────────────────────────────────────
# Example local connection (adjust user/password/host/port/db as needed)
DATABASE_URL=postgresql+asyncpg://localhost:5432/academic_writer

# ── Auth (Google + JWT cookie) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
JWT_SECRET=

# Cookie settings (dev defaults)
COOKIE_SECURE=0
COOKIE_SAMESITE=lax
AUTH_COOKIE_NAME=awa_session

# Optional dev bypass (single implicit user, no Google sign-in)
AUTH_DISABLED=0
DEV_USER_ID=dev-user

# ── Security: per-user encrypted AI keys ─────────────────────────────────────
# Generate with:
# python3 - <<'PY'
# from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
# PY
SETTINGS_ENCRYPTION_KEY=

# ── CORS (comma-separated frontend origins) ──────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── External APIs (optional) ─────────────────────────────────────────────────
NCBI_API_KEY=
